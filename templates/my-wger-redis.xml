  <Config Name="REDIS_DATA" Target="/data" Default="/mnt/user/appdata/wger/redis/" Mode="rw" Description="Verzeichnis f&#xFC;r Redis-Daten (Host: /mnt/user/appdata/wger/redis/)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/wger/redis/</Config>
